<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Mod Merkezi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">MOD MERKEZİ</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/">Keşfet</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= path === '/mods' ? 'active' : '' %>" href="/mods">Modlar</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Kategoriler</a>
                        <ul class="dropdown-menu dropdown-menu-dark border-secondary shadow-lg">
                            <% categories.forEach(category => { %>
                                <li><a class="dropdown-item py-2" href="/kategori/<%= category.id %>"><%= category.name %></a></li>
                            <% }) %>
                        </ul>
                    </li>
                </ul>
                <form class="d-flex me-lg-4" action="/search" method="GET">
                    <div class="input-group">
                        <span class="input-group-text bg-dark-lighter border-secondary border-end-0 text-gray-text rounded-start-pill ps-3">
                            <i class="bi bi-search"></i>
                        </span>
                        <input class="form-control bg-dark-lighter border-secondary border-start-0 rounded-end-pill py-2" type="search" name="q" placeholder="Mod ara..." aria-label="Search">
                    </div>
                </form>
                <ul class="navbar-nav align-items-center">
                    <% if (currentUser) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                                <img src="/uploads/images/<%= currentUser.profile_image %>" class="rounded-circle border border-secondary" width="35" height="35" style="object-fit: cover;">
                                <span class="d-none d-lg-inline"><%= currentUser.username %></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark border-secondary shadow-lg">
                                <li><a class="dropdown-item py-2" href="/profil"><i class="bi bi-person me-2"></i> Profilim</a></li>
                                <li><a class="dropdown-item py-2" href="/mods/yukle"><i class="bi bi-plus-circle me-2"></i> Mod Yükle</a></li>
                                <% if (currentUser.role === 'admin') { %>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li><a class="dropdown-item py-2 text-primary" href="/admin"><i class="bi bi-shield-lock me-2"></i> Yönetim</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider border-secondary"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Çıkış</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Giriş</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-primary px-4 rounded-pill" href="/register">Katıl</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container py-5">
