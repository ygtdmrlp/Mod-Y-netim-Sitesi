<%- include('../partials/header') %>

<div class="bg-white rounded-5 shadow-lg p-5 animate-fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-0">Mod Yönetimi</h2>
        <a href="/admin" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">Admin Paneli</a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
            <thead class="bg-light rounded-4">
                <tr>
                    <th class="border-0 px-3 py-3 rounded-start">Mod</th>
                    <th class="border-0 px-3 py-3 text-center">Durum</th>
                    <th class="border-0 px-3 py-3 text-center">Yükleyen</th>
                    <th class="border-0 px-3 py-3 text-center">Tarih</th>
                    <th class="border-0 px-3 py-3 rounded-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                <% mods.forEach(mod => { %>
                    <tr class="animate-fade-in">
                        <td class="px-3 py-4">
                            <div class="d-flex align-items-center">
                                <img src="/uploads/images/<%= mod.image_path %>" class="rounded-3 me-3" width="60" height="60" style="object-fit: cover;">
                                <div>
                                    <h6 class="fw-bold mb-0"><%= mod.title %></h6>
                                    <small class="text-muted"><%= mod.game_name %> | <%= mod.category_name %></small>
                                </div>
                            </div>
                        </td>
                        <td class="text-center px-3 py-4">
                            <% if (mod.status === 'approved') { %>
                                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Yayında</span>
                            <% } else { %>
                                <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">Onay Bekliyor</span>
                            <% } %>
                        </td>
                        <td class="text-center px-3 py-4 text-muted"><%= mod.uploader_name %></td>
                        <td class="text-center px-3 py-4 text-muted"><%= new Date(mod.created_at).toLocaleDateString('tr-TR') %></td>
                        <td class="px-3 py-4">
                            <div class="d-flex gap-2">
                                <% if (mod.status === 'pending') { %>
                                    <form action="/admin/mods/approve/<%= mod.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-success rounded-circle p-2" title="Onayla"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                <% } %>
                                <form action="/admin/mods/delete/<%= mod.id %>" method="POST" class="d-inline" onsubmit="return confirm('Emin misiniz?')">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-circle p-2" title="Sil"><i class="bi bi-trash"></i></button>
                                </form>
                                <a href="/mods/<%= mod.id %>" class="btn btn-sm btn-light rounded-circle p-2" title="Görüntüle"><i class="bi bi-eye"></i></a>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
