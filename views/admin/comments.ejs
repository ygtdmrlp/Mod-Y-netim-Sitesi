<%- include('../partials/header') %>

<div class="bg-white rounded-5 shadow-lg p-5 animate-fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-0">Yorum Yönetimi</h2>
        <a href="/admin" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">Admin Paneli</a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
            <thead class="bg-light rounded-4">
                <tr>
                    <th class="border-0 px-3 py-3 rounded-start">Kullanıcı</th>
                    <th class="border-0 px-3 py-3 text-center">Mod Başlığı</th>
                    <th class="border-0 px-3 py-3 text-center">Yorum</th>
                    <th class="border-0 px-3 py-3 text-center">Durum</th>
                    <th class="border-0 px-3 py-3 rounded-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                <% comments.forEach(comment => { %>
                    <tr class="animate-fade-in">
                        <td class="px-3 py-4 fw-bold"><%= comment.user_name %></td>
                        <td class="px-3 py-4 text-center text-muted"><%= comment.mod_title %></td>
                        <td class="px-3 py-4 text-muted small" style="max-width: 200px;"><%= comment.comment %></td>
                        <td class="text-center px-3 py-4">
                            <% if (comment.status === 'approved') { %>
                                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">Onaylı</span>
                            <% } else { %>
                                <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">Onay Bekliyor</span>
                            <% } %>
                        </td>
                        <td class="px-3 py-4">
                            <div class="d-flex gap-2">
                                <% if (comment.status === 'pending') { %>
                                    <form action="/admin/comments/approve/<%= comment.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-success rounded-circle p-2" title="Onayla"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                <% } %>
                                <form action="/admin/comments/delete/<%= comment.id %>" method="POST" class="d-inline" onsubmit="return confirm('Emin misiniz?')">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-circle p-2" title="Sil"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
