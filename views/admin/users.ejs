<%- include('../partials/header') %>

<div class="bg-white rounded-5 shadow-lg p-5 animate-fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold mb-0">Kullanıcı Yönetimi</h2>
        <a href="/admin" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">Admin Paneli</a>
    </div>
    
    <div class="table-responsive">
        <table class="table table-hover align-middle border-0">
            <thead class="bg-light rounded-4">
                <tr>
                    <th class="border-0 px-3 py-3 rounded-start">Kullanıcı</th>
                    <th class="border-0 px-3 py-3 text-center">E-posta</th>
                    <th class="border-0 px-3 py-3 text-center">Rol</th>
                    <th class="border-0 px-3 py-3 text-center">Tarih</th>
                    <th class="border-0 px-3 py-3 rounded-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr class="animate-fade-in">
                        <td class="px-3 py-4">
                            <div class="d-flex align-items-center">
                                <img src="/uploads/images/<%= user.profile_image %>" class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                                <div>
                                    <h6 class="fw-bold mb-0"><%= user.username %></h6>
                                </div>
                            </div>
                        </td>
                        <td class="text-center px-3 py-4 text-muted"><%= user.email %></td>
                        <td class="text-center px-3 py-4">
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2"><%= user.role.toUpperCase() %></span>
                        </td>
                        <td class="text-center px-3 py-4 text-muted"><%= new Date(user.created_at).toLocaleDateString('tr-TR') %></td>
                        <td class="px-3 py-4">
                            <div class="d-flex gap-2">
                                <form action="/admin/users/delete/<%= user.id %>" method="POST" class="d-inline" onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?')">
                                    <button type="submit" class="btn btn-sm btn-danger rounded-circle p-2" title="Sil"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
