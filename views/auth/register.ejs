<%- include('../partials/header') %>

<div class="row justify-content-center py-5">
    <div class="col-lg-5">
        <div class="detail-header animate-up shadow-2xl">
            <div class="text-center mb-5">
                <h1 class="fw-bold text-white mb-2" style="letter-spacing: -2px;">Hesap Oluştur</h1>
                <p class="text-gray-text">Topluluğumuza katıl ve modlarını paylaşmaya başla.</p>
            </div>
            
            <% if (error) { %>
                <div class="alert bg-danger bg-opacity-10 text-danger border-danger border-opacity-20 rounded-4 p-3 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <%= error %>
                </div>
            <% } %>

            <form action="/register" method="POST">
                <div class="mb-4">
                    <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Kullanıcı Adı</label>
                    <input type="text" name="username" class="form-control" placeholder="Oyuncu adın" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">E-posta</label>
                    <input type="email" name="email" class="form-control" placeholder="email@ornek.com" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Şifre</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Şifre Tekrar</label>
                    <input type="password" name="confirm_password" class="form-control" placeholder="••••••••" required>
                </div>
                <div class="d-grid gap-3 mb-4">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">Hesap Oluştur</button>
                </div>
                <div class="text-center text-gray-text small">
                    Zaten üye misin? <a href="/login" class="text-primary fw-bold text-decoration-none">Giriş Yap</a>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
