<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-5 animate-fade-in">
    <div>
        <h1 class="fw-bold mb-1"><%= title %></h1>
        <p class="text-white mb-0">Toplam <%= mods.length %> mod bulundu.</p>
    </div>
    <div class="dropdown">
        <button class="btn btn-white bg-white border-0 shadow-sm rounded-pill px-4 py-2 dropdown-toggle fw-bold" type="button" data-bs-toggle="dropdown">
            Sıralama
        </button>
        <ul class="dropdown-menu border-0 shadow-lg rounded-4 overflow-hidden">
            <li><a class="dropdown-item py-2" href="?sort=newest">En Yeniler</a></li>
            <li><a class="dropdown-item py-2" href="?sort=download_count">En Çok İndirilenler</a></li>
            <li><a class="dropdown-item py-2" href="?sort=view_count">En Çok Görüntülenenler</a></li>
        </ul>
    </div>
</div>

<div class="row g-4 mb-5">
    <% if (mods.length === 0) { %>
        <div class="col-12 text-center py-5">
            <div class="display-1 text-white mb-4"><i class="bi bi-search"></i></div>
            <h4 class="text-white">Henüz mod eklenmemiş.</h4>
        </div>
    <% } else { %>
        <% mods.forEach(mod => { %>
            <div class="col-lg-3 col-md-4 col-sm-6 animate-fade-in">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="position-relative overflow-hidden">
                        <img src="/uploads/images/<%= mod.image_path %>" class="card-img-top mod-card-img" alt="<%= mod.title %>">
                        <div class="mod-badge"><i class="bi bi-download me-1"></i> <%= mod.download_count %></div>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge bg-primary-subtle text-primary rounded-pill px-2 py-1" style="font-size: 0.6rem;"><%= mod.game_name %></span>
                            <small class="text-white" style="font-size: 0.7rem;"><%= new Date(mod.created_at).toLocaleDateString('tr-TR') %></small>
                        </div>
                        <h6 class="card-title fw-bold text-truncate mb-1"><a href="/mods/<%= mod.id %>" class="text-white text-decoration-none"><%= mod.title %></a></h6>
                        <div class="d-flex align-items-center text-white small mt-2">
                            <i class="bi bi-person-circle me-1"></i> <%= mod.uploader_name %>
                            <span class="ms-auto"><i class="bi bi-eye"></i> <%= mod.view_count %></span>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include('../partials/footer') %>
