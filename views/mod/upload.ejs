<%- include('../partials/header') %>

<div class="row justify-content-center mb-5">
    <div class="col-lg-8">
        <div class="detail-header animate-up shadow-2xl">
            <div class="text-center mb-5">
                <div class="display-3 text-primary mb-3"><i class="bi bi-rocket-takeoff"></i></div>
                <h1 class="fw-bold text-white mb-2" style="letter-spacing: -2px;">Modunu Paylaş</h1>
                <p class="text-gray-text fs-5">Kendi modunu yükle ve binlerce oyuncuya ulaştır.</p>
            </div>

            <form action="/mods/yukle" method="POST" enctype="multipart/form-data">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Mod Adı</label>
                        <input type="text" name="title" class="form-control" placeholder="Örn: Gerçekçi Işıklandırma V2" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Oyun Adı</label>
                        <input type="text" name="game_name" class="form-control" placeholder="Örn: GTA 5" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Kategori</label>
                        <select name="category_id" class="form-select" required>
                            <option value="">Kategori Seçin</option>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>"><%= category.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Versiyon</label>
                        <input type="text" name="version" class="form-control" placeholder="Örn: 1.0.2" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Açıklama</label>
                        <textarea name="description" class="form-control" rows="5" placeholder="Modun özellikleri, kurulumu ve detaylarını buraya yazın..." required></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Mod Linki (ShareMods vb.)</label>
                        <input type="url" name="mod_link" class="form-control" placeholder="https://sharemods.com/..." required>
                        <div class="form-text text-gray-text small ms-2">Dosya yüklemek yerine link verin</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-gray-text small ms-2 text-uppercase">Mod Görseli</label>
                        <input type="file" name="mod_image" class="form-control" accept="image/*" required>
                        <div class="form-text text-gray-text small ms-2">En iyi sonuç için 16:9 oranında görsel kullanın</div>
                    </div>
                </div>

                <div class="d-grid gap-3 mt-5">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">MODU YAYINLA</button>
                    <a href="/profil" class="btn btn-link text-gray-text text-decoration-none text-center">Vazgeç ve Profile Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
