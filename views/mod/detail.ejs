<%- include('../partials/header') %>

<div class="row g-4 mb-5">
    <div class="col-lg-8">
        <!-- Main Detail Card -->
        <div class="detail-header mb-4 animate-up">
            <div class="position-relative overflow-hidden rounded-4 mb-5 shadow-2xl">
                <img src="/uploads/images/<%= mod.image_path %>" class="w-100" style="max-height: 500px; object-fit: cover;">
                <div class="position-absolute bottom-0 start-0 w-100 p-5 bg-gradient-to-t from-dark to-transparent">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="badge-premium bg-primary border-primary"><%= mod.game_name %></span>
                        <span class="badge-premium"><%= mod.category_name %></span>
                    </div>
                    <h1 class="display-4 fw-bold text-white mb-0" style="letter-spacing: -2px;"><%= mod.title %></h1>
                </div>
            </div>
            
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-4 py-4 border-bottom border-secondary mb-4">
                <div class="d-flex align-items-center gap-3">
                    <img src="/uploads/images/default_profile.png" class="rounded-circle border border-secondary" width="48" height="48">
                    <div>
                        <div class="text-gray-text small">Yükleyen</div>
                        <div class="fw-bold text-white"><%= mod.uploader_name %></div>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <a href="/mods/indir/<%= mod.id %>" target="_blank" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold">
                        <i class="bi bi-box-arrow-up-right me-2"></i> MOD LİNKİNE GİT
                    </a>
                </div>
            </div>
            
            <h4 class="fw-bold text-white mb-4">Mod Hakkında</h4>
            <div class="text-gray-text fs-5 lh-lg mb-5">
                <%= mod.description %>
            </div>
            
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="text-primary fs-3 mb-1"><i class="bi bi-download"></i></div>
                    <div class="fw-bold h4 text-white mb-0"><%= mod.download_count %></div>
                    <small class="text-gray-text">İndirme</small>
                </div>
                <div class="stat-box">
                    <div class="text-secondary fs-3 mb-1"><i class="bi bi-eye"></i></div>
                    <div class="fw-bold h4 text-white mb-0"><%= mod.view_count %></div>
                    <small class="text-gray-text">Görüntülenme</small>
                </div>
                <div class="stat-box">
                    <div class="text-success fs-3 mb-1"><i class="bi bi-code-square"></i></div>
                    <div class="fw-bold h4 text-white mb-0"><%= mod.version %></div>
                    <small class="text-gray-text">Versiyon</small>
                </div>
                <div class="stat-box">
                    <div class="text-warning fs-3 mb-1"><i class="bi bi-chat-dots"></i></div>
                    <div class="fw-bold h4 text-white mb-0"><%= comments.length %></div>
                    <small class="text-gray-text">Yorum</small>
                </div>
            </div>
        </div>

        <!-- Comments Section -->
        <div class="detail-header animate-up" style="animation-delay: 0.2s">
            <h4 class="fw-bold text-white mb-5">Topluluk Yorumları</h4>
            
            <% if (currentUser) { %>
                <form action="/mods/yorum/<%= mod.id %>" method="POST" class="mb-5">
                    <div class="mb-4">
                        <textarea name="comment" class="form-control" rows="4" placeholder="Mod hakkında ne düşünüyorsun?" required></textarea>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">Yorum Gönder</button>
                    </div>
                </form>
            <% } else { %>
                <div class="bg-dark p-4 rounded-4 border border-secondary mb-5 text-center">
                    <p class="text-gray-text mb-0">Yorum yapabilmek için lütfen <a href="/login" class="text-primary fw-bold text-decoration-none">giriş yapın</a>.</p>
                </div>
            <% } %>

            <div class="d-flex flex-column gap-4">
                <% if (comments.length === 0) { %>
                    <div class="text-center py-5">
                        <div class="fs-1 text-gray-text opacity-25 mb-3"><i class="bi bi-chat-square-dots"></i></div>
                        <p class="text-gray-text">Henüz yorum yapılmamış.</p>
                    </div>
                <% } else { %>
                    <% comments.forEach(comment => { %>
                        <div class="bg-dark p-4 rounded-4 border border-secondary">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <img src="/uploads/images/<%= comment.user_image %>" class="rounded-circle" width="40" height="40">
                                <div>
                                    <div class="fw-bold text-white"><%= comment.user_name %></div>
                                    <div class="text-gray-text small"><%= new Date(comment.created_at).toLocaleDateString('tr-TR') %></div>
                                </div>
                            </div>
                            <p class="text-gray-text mb-0"><%= comment.comment %></p>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <div class="sticky-top" style="top: 100px;">
            <div class="detail-header mb-4 animate-up" style="animation-delay: 0.3s">
                <h5 class="fw-bold text-white mb-4">Benzer Modlar</h5>
                <div class="d-flex flex-column gap-3">
                    <% similarMods.forEach(sMod => { %>
                        <a href="/mods/<%= sMod.id %>" class="card text-decoration-none bg-dark border-secondary">
                            <div class="row g-0">
                                <div class="col-4">
                                    <img src="/uploads/images/<%= sMod.image_path %>" class="img-fluid h-100 rounded-start" style="object-fit: cover;">
                                </div>
                                <div class="col-8">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold text-white text-truncate mb-1"><%= sMod.title %></h6>
                                        <div class="text-primary small fw-bold"><%= sMod.game_name %></div>
                                        <div class="d-flex align-items-center gap-2 mt-2 text-gray-text small">
                                            <span><i class="bi bi-download"></i> <%= sMod.download_count %></span>
                                            <span><i class="bi bi-eye"></i> <%= sMod.view_count %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>
            
            <div class="detail-header text-center animate-up" style="animation-delay: 0.4s">
                <h6 class="fw-bold text-white mb-4">Bu Modu Paylaş</h6>
                <div class="d-flex justify-content-center gap-3">
                    <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-whatsapp"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-link-45deg"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
