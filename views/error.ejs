<%- include('partials/header') %>

<div class="text-center py-5 my-5 animate-fade-in">
    <div class="display-1 text-danger mb-4"><i class="bi bi-exclamation-octagon"></i></div>
    <h1 class="fw-bold mb-3">Bir Hata Oluştu!</h1>
    <p class="text-muted mb-5 lead"><%= error.message || 'İstediğiniz sayfa yüklenirken bir hata meydana geldi.' %></p>
    <% if (error.stack) { %>
        <pre class="bg-light p-4 rounded-4 text-start overflow-auto mb-5" style="max-height: 200px; font-size: 0.8rem;"><%= error.stack %></pre>
    <% } %>
    <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-lg">Ana Sayfaya Dön</a>
</div>

<%- include('partials/footer') %>
